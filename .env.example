# Wings of Capital - Environment Variables Template
# Copy this file to .env and fill in actual values for your environment
# NEVER commit .env to version control

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://woc_user:woc_password@postgres:5432/wings_of_capital
TIMESCALE_URL=postgresql://woc_user:woc_password@timescaledb:5432/wings_timescale
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=redis_secret_password
REDIS_SSL=False

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7
PASSWORD_MIN_LENGTH=12
BCRYPT_ROUNDS=12
MFA_ENCRYPTION_KEY=base64-urlsafe-32-byte-key

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_TITLE=Wings of Capital
API_VERSION=1.0.0
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# =============================================================================
# VAULT CONFIGURATION (HashiCorp Vault for secrets)
# =============================================================================
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=s.xxxxxxxxxxxxxxxx
VAULT_PATH=secret/wings

# =============================================================================
# EXTERNAL API KEYS & CREDENTIALS
# =============================================================================
COINGECKO_API_KEY=your-coingecko-api-key
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-alchemy-key
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret

# =============================================================================
# EMAIL CONFIGURATION (for verification, alerts, etc.)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@wingsofcapital.io
SMTP_USE_TLS=True

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_OUTPUT=stdout

# =============================================================================
# CELERY CONFIGURATION (async task processing)
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_MFA=True
ENABLE_API_DOCS=True
ENABLE_TRADING=True
ENABLE_AI_PREDICTIONS=True
RATE_LIMIT_ENABLED=True

# =============================================================================
# CORS & SECURITY HEADERS
# =============================================================================
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization

# =============================================================================
# METRICS & MONITORING
# =============================================================================
PROMETHEUS_ENABLED=True
METRICS_PORT=9090
ENABLE_JAEGER_TRACING=False
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831

# =============================================================================
# STORAGE & FILE UPLOADS
# =============================================================================
MAX_UPLOAD_SIZE_MB=10
UPLOAD_PATH=/app/uploads
S3_BUCKET=wings-of-capital-uploads
S3_REGION=us-east-1

# =============================================================================
# TIER BEETLE LEDGER (if using for accounting)
# =============================================================================
TIGERBEETLE_SERVERS=localhost:9000
TIGERBEETLE_CLUSTER_ID=0

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
FRONTEND_URL=http://localhost:8080
FRONTEND_DEBUG=False

# =============================================================================
# PRODUCTION-ONLY SETTINGS (do not use in development)
# =============================================================================
# SENTRY_DSN=https://xxxxx@sentry.io/xxxx
# DATA_DOG_API_KEY=your-datadog-key
# DB_BACKUP_ENABLED=True
# DB_BACKUP_SCHEDULE=0 2 * * *
# SSL_CERT_PATH=/etc/ssl/certs/server.crt
# SSL_KEY_PATH=/etc/ssl/private/server.key
